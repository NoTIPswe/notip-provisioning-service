{
	"name": "NoTIP Nest Dev",

	"image": "ghcr.io/notipswe/notip-nest-dev:v0.0.1",

	"postCreateCommand": "[ -f package.json ] && npm install; pre-commit install --install-hooks",
	"init": true,

	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"firsttris.vscode-jest-runner",
				"SonarSource.sonarlint-vscode",
				"ms-azuretools.vscode-containers"
			]
		}
	},

	"forwardPorts": [3000],

	"workspaceFolder": "/workspaces/notip-provisioning-service",
	"updateRemoteUserUID": true,
	"remoteUser": "node"
}
